# ──────────────────────────────────────────────────────────────────────
# JukeCoding — environment variables
# Copy to .env (local) and set the same values in Netlify → Site settings →
# Environment variables (production). NEVER commit real secrets — .env is
# git-ignored. VITE_* values are inlined into the public client bundle, so
# only put non-secret/publishable values there.
# ──────────────────────────────────────────────────────────────────────

# ── Client (public — bundled into the site, EmailJS keys are publishable) ──
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_CONTACT_TEMPLATE_ID=
VITE_EMAILJS_OFFERTE_TEMPLATE_ID=

# ── Server: internal worker auth (REQUIRED) ──
# Shared secret between discord-bot and the SEO workers. Without it the workers
# reject every request (fail closed). Generate with: openssl rand -hex 32
INTERNAL_WORKER_SECRET=

# ── Server: Anthropic (SEO workers + scheduled generators) ──
ANTHROPIC_API_KEY=

# ── Server: Discord bot ──
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
DISCORD_SEO_WEBHOOK_URL=

# ── Server: scheduled blog generator (GitHub PR creation) ──
GITHUB_TOKEN=
GITHUB_REPO=
REVIEW_EMAIL=

# ── Provided automatically by Netlify (do not set manually) ──
# URL=  # deploy URL, injected by Netlify at runtime
